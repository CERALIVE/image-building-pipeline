#!/usr/bin/env bash
#
# run-tests — single CI entrypoint for the CeraLive v2 manifest unit suite.
#
# Runs the manifest/orchestrator units plus the hardware-free RK3588 disk contract
# and signed x86 bundle contract. Exits with the bats status so CI can gate on it.
#
# Dependencies (test-time only; NOT shipped in the device image):
#   * bats-core   https://github.com/bats-core/bats-core   (>= 1.5)
#       install:  git clone --depth=1 https://github.com/bats-core/bats-core.git \
#                   && sudo bats-core/install.sh /usr/local
#   * python3 with PyYAML + python-jsonschema (same validator resolve.py uses)
#   * sgdisk, systemd-repart, e2fsprogs, dosfstools, mtools, u-boot-tools
#
# Parallelism (opt-in, automatic):
#   bats parallelizes test files with `-j N`, which needs GNU parallel (or
#   shenwei356/rush) on PATH. This entrypoint enables `-j` automatically when
#   BOTH a parallel backend AND flock are present, and falls back to the
#   previous serial run otherwise — the suite stays green either way. Cases
#   within each Bats file stay serial because they share repo-local fixtures;
#   the three suite files still run in parallel. The few shared fixtures that
#   need finer locking serialize themselves with flock (see `serialize` in
#   tests/manifest.bats).
#   Override the worker count with BATS_JOBS (or PARALLEL_JOBS); unset/0
#   auto-derives from nproc, capped at 8 (this unit suite is 143 short tests —
#   beyond ~8 workers the parallel fan-out overhead outweighs the gain).
#
# Usage:  ./run-tests              (from v2/)         — auto-parallel
#         v2/run-tests             (from repo root)
#         BATS_JOBS=1 v2/run-tests (force serial)
#         BATS_JOBS=8 v2/run-tests (force 8 workers)

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Suites, in run order. The RK3588 contract suite proves the production Rock 5B+
# factory A/B geometry before the signed-bundle suites run.
SUITES=(
  "${HERE}/tests/manifest.bats"
  "${HERE}/tests/rk3588-ab-contract.bats"
  "${HERE}/tests/x86-raucb-bundle.bats"
)
SHELL_SUITES=(
  "${HERE}/tests/fetch-debs-apt-chain.test.sh"
  "${HERE}/tests/bsp-auth-contract.test.sh"
  "${HERE}/tests/bsp-package-resolution.test.sh"
  "${HERE}/tests/rauc-pki-contract.test.sh"
  "${HERE}/tests/release-candidate-contract.test.sh"
  "${HERE}/tests/preflash-fit.test.sh"
  "${HERE}/tests/maskrom-first-realhw.test.sh"
  "${HERE}/tests/systemd-ordering-cycle.test.sh"
  "${HERE}/tests/ssh-firstboot-privsep.test.sh"
  "${HERE}/tests/data-persistence-public-symlink.test.sh"
  "${HERE}/tests/hardware-launch-contract.test.sh"
  "${HERE}/tests/release-cache-contract.test.sh"
  "${HERE}/tests/builder-resource-budget.test.sh"
  "${HERE}/tests/mkosi-package-staging.test.sh"
  "${HERE}/tests/immutable-r2-publication.test.sh"
  "${HERE}/tests/recovery-script-contract.test.sh"
  "${HERE}/tests/production-ci-scope-contract.test.sh"
  "${HERE}/tests/orchestrate-build-lock.test.sh"
  "${HERE}/tests/boot-script-sanitize.test.sh"
  "${HERE}/mkosi/platform/boot/test-fallback.sh"
)
DEV_PKI_GENERATOR="${HERE}/tests/generate-dev-rauc-pki.sh"

if ! command -v bats >/dev/null 2>&1; then
  cat >&2 <<'EOF'
ERROR: bats-core not found on PATH (test-time dependency).
Install it, then re-run:
  git clone --depth=1 https://github.com/bats-core/bats-core.git /tmp/bats-core
  sudo /tmp/bats-core/install.sh /usr/local
EOF
  exit 127
fi

for suite in "${SUITES[@]}"; do
  if [[ ! -f "${suite}" ]]; then
    echo "ERROR: test suite not found: ${suite}" >&2
    exit 1
  fi
done
for suite in "${SHELL_SUITES[@]}"; do
  if [[ ! -x "${suite}" ]]; then
    echo "ERROR: shell test suite not found or not executable: ${suite}" >&2
    exit 1
  fi
done
if [[ ! -x "${DEV_PKI_GENERATOR}" ]]; then
  echo "ERROR: dev RAUC PKI generator not found or not executable: ${DEV_PKI_GENERATOR}" >&2
  exit 1
fi

"${DEV_PKI_GENERATOR}"

for suite in "${SHELL_SUITES[@]}"; do
  "${suite}"
done

# --- Decide on parallelism -------------------------------------------------
jobs="${BATS_JOBS:-${PARALLEL_JOBS:-0}}"
[[ "$jobs" =~ ^[0-9]+$ ]] || jobs=0           # non-numeric override -> auto
if [[ "$jobs" -eq 0 ]]; then
  ncpu="$(nproc 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)"
  [[ "$ncpu" =~ ^[0-9]+$ && "$ncpu" -ge 1 ]] || ncpu=1
  jobs=$(( ncpu < 8 ? ncpu : 8 ))
fi

parallel_backend=""
if command -v parallel >/dev/null 2>&1; then
  parallel_backend="GNU parallel"
elif command -v rush >/dev/null 2>&1; then
  parallel_backend="rush"
fi

bats_args=()
if [[ "$jobs" -gt 1 && -n "$parallel_backend" ]] && command -v flock >/dev/null 2>&1; then
  bats_args+=( --jobs "$jobs" --no-parallelize-within-files )
  mode="parallel — ${jobs} jobs via ${parallel_backend} (file-serial)"
else
  mode="serial"
  if [[ "$jobs" -gt 1 && -z "$parallel_backend" ]]; then
    echo "note: GNU parallel (or rush) not on PATH; running serially." \
         "Install GNU parallel to parallelize this suite (~2-3x faster on CI)." >&2
  fi
fi

echo "== CeraLive v2 unit suites (bats $(bats --version | awk '{print $2}')) — ${mode} =="
bats ${bats_args[@]+"${bats_args[@]}"} "${SUITES[@]}"

echo "== CeraLive v2 mock RAUC rollback suite =="
CERALIVE_ROLLBACK_MODE=mock bash "${HERE}/tests/rauc-rollback.sh"

# The RK3588 Bats suite invokes preflash-verify.sh --self-test against its real
# signed-bundle fixture. The privileged RAUC service harness is opt-in locally
# and required by CI so a developer machine is never mounted on unexpectedly.
case "${CERALIVE_RUN_REAL_RAUC_CONTRACT:-skip}" in
  required)
    echo "== CeraLive v2 real RAUC interruption/cleanup contract =="
    bash "${HERE}/tests/real-rauc-contract.sh"
    bash "${HERE}/tests/real-rauc-cleanup-contract.test.sh"
    ;;
  skip)
    echo "== SKIP real RAUC contract (set CERALIVE_RUN_REAL_RAUC_CONTRACT=required) =="
    ;;
  *)
    echo "ERROR: CERALIVE_RUN_REAL_RAUC_CONTRACT must be 'required' or 'skip'" >&2
    exit 2
    ;;
esac
