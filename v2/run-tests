#!/usr/bin/env bash
#
# run-tests — single CI entrypoint for the CeraLive v2 manifest unit suite.
#
# Runs the bats-core unit tests for the manifest system (schema validation,
# resolver merge precedence, versions.yaml pin resolution, common.sh strict-fail).
# Exits with the bats exit code so CI can gate on it directly.
#
# Dependencies (test-time only; NOT shipped in the device image):
#   * bats-core   https://github.com/bats-core/bats-core   (>= 1.5)
#       install:  git clone --depth=1 https://github.com/bats-core/bats-core.git \
#                   && sudo bats-core/install.sh /usr/local
#   * python3 with PyYAML + python-jsonschema (same validator resolve.py uses)
#
# Parallelism (opt-in, automatic):
#   bats parallelizes test CASES with `-j N`, which needs GNU parallel (or
#   shenwei356/rush) on PATH. This entrypoint enables `-j` automatically when
#   BOTH a parallel backend AND flock are present, and falls back to the
#   previous serial run otherwise — the suite stays green either way. The few
#   tests that share mutable state (the working tree in §8, the per-file
#   feature-sysext fixture in §14) serialize themselves with flock (see the
#   `serialize` helper in tests/manifest.bats), so parallel runs are correct.
#   Override the worker count with BATS_JOBS (or PARALLEL_JOBS); unset/0
#   auto-derives from nproc, capped at 8 (this unit suite is ~95 short tests —
#   beyond ~8 workers the parallel fan-out overhead outweighs the gain).
#
# Usage:  ./run-tests              (from v2/)         — auto-parallel
#         v2/run-tests             (from repo root)
#         BATS_JOBS=1 v2/run-tests (force serial)
#         BATS_JOBS=8 v2/run-tests (force 8 workers)

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Suites, in run order. manifest.bats is the manifest/orchestrator unit suite;
# x86-raucb-bundle.bats is the offline REAL x86 .raucb sign/verify/tamper gate (T10).
SUITES=(
  "${HERE}/tests/manifest.bats"
  "${HERE}/tests/x86-raucb-bundle.bats"
)
SHELL_SUITES=(
  "${HERE}/tests/fetch-debs-apt-chain.test.sh"
)

if ! command -v bats >/dev/null 2>&1; then
  cat >&2 <<'EOF'
ERROR: bats-core not found on PATH (test-time dependency).
Install it, then re-run:
  git clone --depth=1 https://github.com/bats-core/bats-core.git /tmp/bats-core
  sudo /tmp/bats-core/install.sh /usr/local
EOF
  exit 127
fi

for suite in "${SUITES[@]}"; do
  if [[ ! -f "${suite}" ]]; then
    echo "ERROR: test suite not found: ${suite}" >&2
    exit 1
  fi
done
for suite in "${SHELL_SUITES[@]}"; do
  if [[ ! -x "${suite}" ]]; then
    echo "ERROR: shell test suite not found or not executable: ${suite}" >&2
    exit 1
  fi
done

for suite in "${SHELL_SUITES[@]}"; do
  "${suite}"
done

# --- Decide on parallelism -------------------------------------------------
jobs="${BATS_JOBS:-${PARALLEL_JOBS:-0}}"
[[ "$jobs" =~ ^[0-9]+$ ]] || jobs=0           # non-numeric override -> auto
if [[ "$jobs" -eq 0 ]]; then
  ncpu="$(nproc 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)"
  [[ "$ncpu" =~ ^[0-9]+$ && "$ncpu" -ge 1 ]] || ncpu=1
  jobs=$(( ncpu < 8 ? ncpu : 8 ))
fi

parallel_backend=""
if command -v parallel >/dev/null 2>&1; then
  parallel_backend="GNU parallel"
elif command -v rush >/dev/null 2>&1; then
  parallel_backend="rush"
fi

bats_args=()
if [[ "$jobs" -gt 1 && -n "$parallel_backend" ]] && command -v flock >/dev/null 2>&1; then
  bats_args+=( --jobs "$jobs" )
  mode="parallel — ${jobs} jobs via ${parallel_backend}"
else
  mode="serial"
  if [[ "$jobs" -gt 1 && -z "$parallel_backend" ]]; then
    echo "note: GNU parallel (or rush) not on PATH; running serially." \
         "Install GNU parallel to parallelize this suite (~2-3x faster on CI)." >&2
  fi
fi

echo "== CeraLive v2 unit suites (bats $(bats --version | awk '{print $2}')) — ${mode} =="
exec bats ${bats_args[@]+"${bats_args[@]}"} "${SUITES[@]}"
