# CeraLive x86 A/B boot selector — GRUB config SOURCE TEMPLATE.
#
# Rendered to grub.cfg by install-x86-boot.sh (placeholders @...@ are substituted
# at build time; the @DECREMENT_*@ ladders are GENERATED for BOOT_ATTEMPTS). The
# rendered grub.cfg lives next to grubenv on the EFI System Partition (e.g.
# /EFI/ceralive/grub.cfg), so GRUB's `load_env` (which reads $prefix/grubenv) and
# userspace (x86-boot-state via grub-editenv) read+write the SAME state.
#
# WHY a hand-written selector and not RAUC's stock grub.cfg (decision, README.md):
# we keep the RK3588 multi-attempt COUNTDOWN model (BOOT_<slot>_LEFT 3->2->1->0),
# not RAUC's single boolean retry, so both platforms behave identically. This file
# is the GRUB-script twin of x86-boot-state.sh `boot-select`; test-x86-fallback.sh
# proves they stay equivalent.
#
# ALGORITHM (twin of x86-boot-state.sh `boot-select` and of the RK3588 boot.scr.cmd):
#   1. load A/B state (BOOT_ORDER, BOOT_A_LEFT, BOOT_B_LEFT) from grubenv
#   2. pick the first slot in BOOT_ORDER whose *_LEFT > 0   (the "primary")
#   3. DECREMENT that slot's counter and persist (save_env)  -> an OS that never
#      marks itself good bleeds 3->2->1->0 and the NEXT boot skips it
#   4. if every counter is exhausted, last-resort boot the head of BOOT_ORDER
#   5. boot kernel+initrd from the chosen rootfs slot, root=PARTLABEL=rootfs_<a|b>
#
# GRUB HAS NO ARITHMETIC. U-Boot has `setexpr` (real LEFT = LEFT - 1); GRUB script
# has only integer COMPARISON (`-gt`) and string equality — no `$(( ))`, no setexpr.
# So the decrement (step 3) is a BOUNDED STRING-COMPARISON LADDER, generated for the
# configured BOOT_ATTEMPTS by install-x86-boot.sh and injected at @DECREMENT_A@ /
# @DECREMENT_B@. The LEFT>0 selection test (step 2) DOES use GRUB's integer `-gt`.

insmod part_gpt
insmod ext2
insmod fat
insmod search_label
insmod test
insmod echo

set timeout=1
set default=0

# board serial console (from the family manifest serial_console, ':' -> ',')
set cera_console="@CONSOLE@"

# --- A/B state defaults (safe if grubenv is missing/partial); load_env overrides
set BOOT_ORDER="A B"
set BOOT_A_LEFT=@BOOT_ATTEMPTS@
set BOOT_B_LEFT=@BOOT_ATTEMPTS@
load_env
echo "CeraLive A/B: BOOT_ORDER=${BOOT_ORDER} A_LEFT=${BOOT_A_LEFT} B_LEFT=${BOOT_B_LEFT}"

# --- pick the first slot in BOOT_ORDER with attempts remaining (the primary)
set cera_slot=""
for s in ${BOOT_ORDER}; do
  if [ -z "${cera_slot}" ]; then
    if [ "${s}" = "A" ]; then
      if [ "${BOOT_A_LEFT}" -gt 0 ]; then set cera_slot="A"; fi
    fi
    if [ "${s}" = "B" ]; then
      if [ "${BOOT_B_LEFT}" -gt 0 ]; then set cera_slot="B"; fi
    fi
  fi
done

# --- all counters exhausted -> last-resort boot the head of BOOT_ORDER (no decrement)
set cera_exhausted=0
if [ -z "${cera_slot}" ]; then
  set cera_exhausted=1
  for s in ${BOOT_ORDER}; do
    if [ -z "${cera_slot}" ]; then set cera_slot="${s}"; fi
  done
  echo "CeraLive: all slots exhausted — last-resort booting ${cera_slot}"
fi

# --- decrement the chosen slot's counter and persist (skip when exhausted: nothing
#     left to spend). GRUB has no arithmetic -> string-comparison ladder for
#     BOOT_ATTEMPTS, generated by install-x86-boot.sh. This is the bootcount step
#     that drives automatic rollback.
if [ "${cera_exhausted}" = "0" ]; then
  if [ "${cera_slot}" = "A" ]; then
@DECREMENT_A@
    save_env BOOT_A_LEFT
    echo "CeraLive: A attempts now ${BOOT_A_LEFT} (persisted)"
  fi
  if [ "${cera_slot}" = "B" ]; then
@DECREMENT_B@
    save_env BOOT_B_LEFT
    echo "CeraLive: B attempts now ${BOOT_B_LEFT} (persisted)"
  fi
fi

# --- resolve the chosen slot's rootfs PARTLABEL (contract: A->rootfs_a, B->rootfs_b)
set cera_root="rootfs_a"
if [ "${cera_slot}" = "B" ]; then set cera_root="rootfs_b"; fi
echo "CeraLive: booting slot ${cera_slot} (root=PARTLABEL=${cera_root})"

# --- auto entry (default=0): boots the slot selected above. Kernel/initrd ride
#     INSIDE the rootfs slot (Debian /vmlinuz + /initrd.img symlinks track the
#     current kernel), so `search` sets root to that ext4 slot by GPT label.
menuentry "CeraLive (auto: slot ${cera_slot})" --id ceralive-auto {
  search --no-floppy --label --set=root ${cera_root}
  linux /vmlinuz root=/dev/disk/by-partlabel/${cera_root} rootwait rw console=${cera_console} cera_slot=${cera_slot}
  initrd /initrd.img
}

# --- manual recovery entries (console operator only; NOT the rollback path, no
#     counter touch — analogous to the RK3588 extlinux recovery menu).
menuentry "CeraLive recovery: slot A (rootfs_a)" --id ceralive-a {
  search --no-floppy --label --set=root rootfs_a
  linux /vmlinuz root=/dev/disk/by-partlabel/rootfs_a rootwait rw console=${cera_console} cera_slot=A
  initrd /initrd.img
}
menuentry "CeraLive recovery: slot B (rootfs_b)" --id ceralive-b {
  search --no-floppy --label --set=root rootfs_b
  linux /vmlinuz root=/dev/disk/by-partlabel/rootfs_b rootwait rw console=${cera_console} cera_slot=B
  initrd /initrd.img
}
