# CeraLive board specifics for the U-Boot A/B selector (boot.scr).
#
# TEMPLATE — rendered by install-boot.sh at build time from the board+family
# manifest (lib/resolve.sh -> environment). Comment/blank lines are STRIPPED on
# render so the shipped file is pure KEY=value (safe for U-Boot `env import -t`,
# which would otherwise treat a stray comment as a bogus variable). NEVER hardcode
# a board value here; the placeholders below come from the manifest:
#   CONSOLE   <- family serial_console (ttyS2:1500000 rendered as ttyS2,1500000)
#   DTB_NAME  <- board  dtb_name       (e.g. rk3588-rock-5b-plus.dtb)
#   BOARD_ID  <- board  board_id       (e.g. rock-5b-plus)
console=@CONSOLE@
fdtfile=@DTB_NAME@
board_id=@BOARD_ID@
