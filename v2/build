#!/usr/bin/env bash
#
# build — manifest-dispatch entry point for the CeraLive v2 image pipeline.
#
# Contract:
#   build <board>            build a single board (default; unchanged behaviour)
#   build --all              build every manifest in manifests/boards/
#   build --only b1,b2       build the named subset (each must have a manifest)
#
#   <board> must correspond to a manifest in manifests/boards/<board>.<ext>.
#   Board data (kernel branch, partition sizing, package sets, …) lives ENTIRELY
#   in those manifests — never hardcoded here (see task 11). This entry only:
#     1. resolves the requested selection against the manifest directory, and
#     2. dispatches: a single resolved board execs the orchestrator (task 16);
#        a multi-board selection is handed to the bounded-parallel runner
#        (lib/build-all.sh, task 12), which builds the boards concurrently and
#        exits non-zero if ANY board fails. DRY_RUN=1 previews a multi-board
#        selection (board list printed, exit 0) before the runner is reached.
#
# Fails loudly: missing arg -> usage; unknown board -> lists available manifests;
#               unknown board inside --only -> names it and lists available.
#
# shellcheck shell=bash

# Resolve this script's own directory so it works from any CWD.
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/common.sh
source "${HERE}/lib/common.sh"

BOARDS_DIR="${HERE}/manifests/boards"
ORCHESTRATOR="${HERE}/lib/orchestrate.sh" # provided by task 16
BUILD_ALL="${HERE}/lib/build-all.sh"      # bounded-parallel multi-board runner (task 12)

usage() {
  cat >&2 <<EOF
Usage:
  build <board>          build a single board
  build --all            build every board manifest
  build --only b1,b2     build the named subset (comma-separated)

Board definitions are read from manifests under:
  ${BOARDS_DIR}/

A single resolved board execs the orchestrator. A multi-board selection is
handed to the bounded-parallel runner (lib/build-all.sh): boards build
concurrently (bounded by JOBS), each to its own log under v2/logs/, and the run
exits non-zero if ANY board fails. DRY_RUN=1 previews the resolved board list
(printed, exit 0) before the runner is reached.
EOF
}

# Collect available board names from manifest files (any of the common manifest
# extensions). Populates the global array AVAILABLE_BOARDS.
collect_boards() {
  AVAILABLE_BOARDS=()
  local f name
  for f in "${BOARDS_DIR}"/*.yaml "${BOARDS_DIR}"/*.yml \
           "${BOARDS_DIR}"/*.toml "${BOARDS_DIR}"/*.conf; do
    [[ -e "${f}" ]] || continue
    name="$(basename "${f}")"
    AVAILABLE_BOARDS+=("${name%.*}")
  done
}

list_available() {
  collect_boards
  if [[ ${#AVAILABLE_BOARDS[@]} -eq 0 ]]; then
    log_error "no board manifests present yet in ${BOARDS_DIR}/ (added in task 11)"
    return
  fi
  log_error "available boards: ${AVAILABLE_BOARDS[*]}"
}

# Resolve a board name to its manifest path on stdout (first matching extension
# wins). Returns non-zero with no output when no manifest exists for the board.
find_manifest() {
  local board="$1" ext
  for ext in yaml yml toml conf; do
    if [[ -f "${BOARDS_DIR}/${board}.${ext}" ]]; then
      printf '%s\n' "${BOARDS_DIR}/${board}.${ext}"
      return 0
    fi
  done
  return 1
}

# Single-board dispatch: exec the orchestrator (task 16) exactly as before. Any
# trailing args (after the positional board) are forwarded verbatim.
dispatch_single() {
  local board="$1" manifest="$2"
  shift 2

  log_info "selected board '${board}' -> ${manifest}"

  # Delegate to the orchestrator (task 16). Until it lands, fail loudly rather
  # than pretend success — no best-effort stubs that silently no-op.
  if [[ ! -x "${ORCHESTRATOR}" ]]; then
    die "orchestrator not yet available at ${ORCHESTRATOR} (implemented in task 16)"
  fi

  log_info "delegating to orchestrator for board '${board}'"
  exec "${ORCHESTRATOR}" --board "${board}" --manifest "${manifest}" "$@"
}

# Multi-board dispatch. Resolve every board's manifest (fail loud on any miss),
# then hand the selection to the bounded-parallel runner (build-all.sh, task 12),
# which builds the boards concurrently — one orchestrate.sh per board, each to its
# own log — and exits non-zero if ANY board fails. DRY_RUN=1 still short-circuits
# to a preview here (print the resolved list, exit 0) BEFORE reaching the runner.
dispatch_multi() {
  local -a boards=("$@")

  log_info "resolved ${#boards[@]} boards: ${boards[*]}"

  if [[ "${DRY_RUN:-0}" == "1" ]]; then
    log_info "[DRY_RUN] multi-board selection (${#boards[@]}): ${boards[*]}"
    log_info "[DRY_RUN] parallel orchestration preview only; board list resolved, exiting 0"
    exit 0
  fi

  # Validate each board resolves to a manifest before launching — the runner
  # re-resolves them, but failing here keeps the loud, named error in one place.
  local b
  for b in "${boards[@]}"; do
    if ! find_manifest "${b}" >/dev/null; then
      log_error "unknown board: '${b}'"
      list_available
      exit 1
    fi
  done

  if [[ ! -x "${BUILD_ALL}" ]]; then
    die "parallel runner not executable at ${BUILD_ALL}"
  fi

  log_info "delegating ${#boards[@]} boards to the parallel runner: ${BUILD_ALL}"
  # exec so the runner's aggregate exit status (non-zero if ANY board fails)
  # propagates as this command's exit status.
  exec "${BUILD_ALL}" "${boards[@]}"
}

main() {
  local mode="single"
  local only_csv=""
  local board=""
  local -a passthrough=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all)
        mode="all"
        shift
        ;;
      --only)
        mode="only"
        only_csv="${2:-}"
        if [[ -z "${only_csv}" ]]; then
          usage
          die "--only requires a comma-separated board list (e.g. --only rock-5b-plus,x86-minipc)"
        fi
        shift 2
        ;;
      --only=*)
        mode="only"
        only_csv="${1#--only=}"
        if [[ -z "${only_csv}" ]]; then
          usage
          die "--only requires a comma-separated board list (e.g. --only rock-5b-plus,x86-minipc)"
        fi
        shift
        ;;
      --)
        shift
        passthrough+=("$@")
        break
        ;;
      -*)
        usage
        die "unknown option: '$1'"
        ;;
      *)
        if [[ "${mode}" != "single" ]]; then
          usage
          die "positional board '$1' cannot be combined with --${mode}"
        fi
        if [[ -n "${board}" ]]; then
          usage
          die "only one positional <board> is allowed (got '${board}' and '$1'); use --all or --only for multiple"
        fi
        board="$1"
        shift
        ;;
    esac
  done

  # Resolve the requested selection into SELECTED_BOARDS.
  local -a SELECTED_BOARDS=()
  case "${mode}" in
    single)
      if [[ -z "${board}" ]]; then
        usage
        die "missing required argument: <board> (or use --all / --only b1,b2)"
      fi
      SELECTED_BOARDS=("${board}")
      ;;
    all)
      collect_boards
      if [[ ${#AVAILABLE_BOARDS[@]} -eq 0 ]]; then
        die "--all requested but no board manifests present in ${BOARDS_DIR}/"
      fi
      SELECTED_BOARDS=("${AVAILABLE_BOARDS[@]}")
      log_info "--all resolved to ${#SELECTED_BOARDS[@]} boards: ${SELECTED_BOARDS[*]}"
      ;;
    only)
      local -a requested=() invalid=()
      local b
      IFS=',' read -r -a requested <<< "${only_csv}"
      for b in "${requested[@]}"; do
        b="${b#"${b%%[![:space:]]*}"}"   # ltrim
        b="${b%"${b##*[![:space:]]}"}"   # rtrim
        [[ -n "${b}" ]] || continue
        if find_manifest "${b}" >/dev/null; then
          SELECTED_BOARDS+=("${b}")
        else
          invalid+=("${b}")
        fi
      done
      if [[ ${#invalid[@]} -gt 0 ]]; then
        log_error "--only: unknown board(s): ${invalid[*]}"
        list_available
        exit 1
      fi
      if [[ ${#SELECTED_BOARDS[@]} -eq 0 ]]; then
        usage
        die "--only resolved to no boards (empty selection)"
      fi
      ;;
  esac

  # Dispatch on the COUNT of resolved boards: one board still execs the
  # orchestrator exactly as before; more than one goes to the parallel runner.
  if [[ ${#SELECTED_BOARDS[@]} -eq 1 ]]; then
    local one="${SELECTED_BOARDS[0]}"
    local manifest
    if ! manifest="$(find_manifest "${one}")"; then
      log_error "unknown board: '${one}'"
      list_available
      exit 1
    fi
    dispatch_single "${one}" "${manifest}" "${passthrough[@]}"
  else
    dispatch_multi "${SELECTED_BOARDS[@]}"
  fi
}

main "$@"
