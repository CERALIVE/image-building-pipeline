# CeraLive private hawkBit engine — environment template (Stage 7, task 40).
#
#   cp hawkbit.env.example .env  &&  $EDITOR .env  &&  docker-compose up -d
#
# THIS FILE IS DOCUMENTATION ONLY — the values below are PLACEHOLDERS, not secrets.
# Never commit your real .env (it is gitignored). Every var here is consumed by
# docker-compose.yml; compose FAILS CLOSED (`${VAR:?...}`) if a required one is unset,
# so there is no way to boot with blank/default credentials.

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL (dedicated DB for hawkBit)
# ─────────────────────────────────────────────────────────────────────────────
HAWKBIT_DB_NAME=hawkbit
HAWKBIT_DB_USER=hawkbit
# Use a long random secret in production, e.g.:  openssl rand -base64 24
HAWKBIT_DB_PASSWORD=change-me-postgres-password

# ─────────────────────────────────────────────────────────────────────────────
# hawkBit admin login (built-in user store — NO admin:admin default)
# ─────────────────────────────────────────────────────────────────────────────
# Pick any username — do NOT use "admin" with a weak password.
HAWKBIT_ADMIN_USER=ceralive-ops

# The password MUST be a Spring Security encoded string. Two accepted forms:
#   {bcrypt}$2a$10$....    ← STRONGLY PREFERRED (hash, never plaintext at rest)
#   {noop}plain-text       ← only for a throwaway local test, never in production
#
# Generate a bcrypt-encoded value (requires apache2-utils / httpd-tools for htpasswd):
#   htpasswd -bnBC 10 "" 'your-real-password' | tr -d ':\n' | sed 's/^/{bcrypt}/'
#
# The placeholder below is the bcrypt hash of the literal string "change-me" — it is
# intentionally a known/throwaway value so this file carries NO usable secret. REPLACE IT.
HAWKBIT_ADMIN_PASSWORD={bcrypt}$2a$10$7EqJtq98hPqEX7fNZaFWoOhi5.Gq1pXxq8t6QbVnJ0bN0G0Z3qYJK

# ─────────────────────────────────────────────────────────────────────────────
# External artifact store → R2 (served by apt-worker /bundles, task 39)
# ─────────────────────────────────────────────────────────────────────────────
# hawkBit stores ONLY artifact metadata; the device download link is built from this
# base + "/{artifactFileName}". Point it at the channel/board prefix you publish to.
# Bundle content-type at this path is application/vnd.rauc.bundle with HTTP range support.
#   stable channel, Rock 5B+:   https://apt.ceralive.tv/bundles/stable/rock-5b-plus
#   stable channel, OrangePi5+: https://apt.ceralive.tv/bundles/stable/orangepi5plus
R2_BUNDLE_BASE_URL=https://apt.ceralive.tv/bundles/stable/rock-5b-plus

# ─────────────────────────────────────────────────────────────────────────────
# provision.sh inputs (one-time distribution-set setup; not read by compose)
# ─────────────────────────────────────────────────────────────────────────────
# Base URL provision.sh talks to (the loopback-published Management API).
HAWKBIT_URL=http://127.0.0.1:8080
# RAUC `compatible` string for the example distribution set's target filter.
# Format is ceralive-${FAMILY} (mkosi/runtime/rauc/system.conf): ceralive-rk3588, ceralive-x86.
RAUC_COMPATIBLE=ceralive-rk3588
# Example bundle the distribution set references (filename only; joined onto R2_BUNDLE_BASE_URL).
EXAMPLE_BUNDLE_FILE=20260603T140027Z.raucb
EXAMPLE_BUNDLE_VERSION=2026.06.03
